class Product:
    _counter = 1

    def __init__(self, nazwa, kategoria, ilosc, cena_sztuka):
        self.product_id = Product._counter
        Product._counter += 1

        self.nazwa = nazwa
        self.kategoria = kategoria
        self.ilosc = ilosc
        self.cena_sztuka = cena_sztuka

    def oblicz_wartosc(self):
        return self.ilosc * self.cena_sztuka

    def __str__(self):
        return (
            f"ID: {self.product_id}, "
            f"nazwa: {self.nazwa}, "
            f"kategoria: {self.kategoria}, "
            f"ilość: {self.ilosc}, "
            f"cena/szt: {self.cena_sztuka} zł, "
            f"wartość: {self.oblicz_wartosc()} zł"
        )

