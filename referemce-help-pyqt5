# Przykład 3 — ewidencja eksploatacyjna

```python
import sys
import json
from datetime import datetime

from PyQt5.QtWidgets import (
    QApplication,
    QMainWindow,
    QWidget,
    QVBoxLayout,
    QHBoxLayout,
    QLabel,
    QLineEdit,
    QPushButton,
    QTableWidget,
    QTableWidgetItem,
    QMessageBox,
    QFileDialog
)

from matplotlib.backends.backend_qt5agg import FigureCanvasQTAgg as FigureCanvas
from matplotlib.figure import Figure


class Wpis:
    def __init__(self, id, identyfikator, data, licznik, ilosc, koszt):
        self.id = id
        self.identyfikator = identyfikator
        self.data = data
        self.licznik = licznik
        self.ilosc = ilosc
        self.koszt = koszt


class EwidencjaManager:
    def __init__(self):
        self.wpisy = []

    def dodaj_wpis(self, wpis):
        self.wpisy.append(wpis)

    def wyczysc_dane(self):
        self.wpisy.clear()

    def pobierz_koszty_per_obiekt(self):
        koszty = {}

        for wpis in self.wpisy:
            identyfikator = wpis.identyfikator

            if identyfikator not in koszty:
                koszty[identyfikator] = 0

            koszty[identyfikator] += wpis.koszt

        return koszty

    def oblicz_srednia_wartosc(self, identyfikator):
        wpisy_obiektu = []

        for wpis in self.wpisy:
            if wpis.identyfikator == identyfikator:
                wpisy_obiektu.append(wpis)

        if len(wpisy_obiektu) < 2:
            return 0

        wpisy_obiektu.sort(key=lambda x: x.licznik)

        pierwszy = wpisy_obiektu[0]
        ostatni = wpisy_obiektu[-1]

        roznica = ostatni.licznik - pierwszy.licznik

        if roznica <= 0:
            return 0

        suma_ilosci = 0

        for wpis in wpisy_obiektu[1:]:
            suma_ilosci += wpis.ilosc

        return suma_ilosci / roznica * 100

    def pobierz_srednie_wszystkich_obiektow(self):
        wynik = {}

        for wpis in self.wpisy:
            identyfikator = wpis.identyfikator

            if identyfikator not in wynik:
                srednia = self.oblicz_srednia_wartosc(identyfikator)

                if srednia > 0:
                    wynik[identyfikator] = srednia

        return wynik

    def zapisz_baze(self, sciezka):
        dane = []

        for wpis in self.wpisy:
            dane.append(wpis.__dict__)

        with open(sciezka, "w", encoding="utf-8") as plik:
            json.dump(dane, plik, ensure_ascii=False, indent=4)

    def wczytaj_baze(self, sciezka):
        with open(sciezka, "r", encoding="utf-8") as plik:
            dane = json.load(plik)

        self.wpisy = []

        for element in dane:
            wpis = Wpis(**element)
            self.wpisy.append(wpis)


class MainWindow(QMainWindow):
    def __init__(self):
        super().__init__()

        self.manager = EwidencjaManager()

        self.setWindowTitle("Ewidencja danych")
        self.setGeometry(200, 200, 1000, 700)

        self.utworz_interfejs()

    def utworz_interfejs(self):
        glowny_widget = QWidget()
        glowny_layout = QVBoxLayout()

        formularz_layout = QHBoxLayout()

        self.input_identyfikator = QLineEdit()
        self.input_licznik = QLineEdit()
        self.input_ilosc = QLineEdit()
        self.input_koszt = QLineEdit()

        self.input_identyfikator.setPlaceholderText("Identyfikator")
        self.input_licznik.setPlaceholderText("Licznik")
        self.input_ilosc.setPlaceholderText("Ilość")
        self.input_koszt.setPlaceholderText("Koszt")

        formularz_layout.addWidget(QLabel("Identyfikator:"))
        formularz_layout.addWidget(self.input_identyfikator)

        formularz_layout.addWidget(QLabel("Licznik:"))
        formularz_layout.addWidget(self.input_licznik)

        formularz_layout.addWidget(QLabel("Ilość:"))
        formularz_layout.addWidget(self.input_ilosc)

        formularz_layout.addWidget(QLabel("Koszt:"))
        formularz_layout.addWidget(self.input_koszt)

        przyciski_layout = QHBoxLayout()

        self.przycisk_dodaj = QPushButton("Dodaj wpis")
        self.przycisk_zapisz = QPushButton("Zapisz")
        self.przycisk_wczytaj = QPushButton("Wczytaj")
        self.przycisk_wyczysc = QPushButton("Wyczyść")
        self.przycisk_wykres = QPushButton("Odśwież wykres")

        self.przycisk_dodaj.clicked.connect(self.dodaj_wpis_z_formularza)
        self.przycisk_zapisz.clicked.connect(self.zapisz_json)
        self.przycisk_wczytaj.clicked.connect(self.wczytaj_json)
        self.przycisk_wyczysc.clicked.connect(self.wyczysc_dane)
        self.przycisk_wykres.clicked.connect(self.rysuj_wykres)

        przyciski_layout.addWidget(self.przycisk_dodaj)
        przyciski_layout.addWidget(self.przycisk_zapisz)
        przyciski_layout.addWidget(self.przycisk_wczytaj)
        przyciski_layout.addWidget(self.przycisk_wyczysc)
        przyciski_layout.addWidget(self.przycisk_wykres)

        self.tabela = QTableWidget()
        self.tabela.setColumnCount(6)
        self.tabela.setHorizontalHeaderLabels([
            "ID",
            "Identyfikator",
            "Data",
            "Licznik",
            "Ilość",
            "Koszt"
        ])

        self.figure = Figure(figsize=(5, 3))
        self.canvas = FigureCanvas(self.figure)

        glowny_layout.addLayout(formularz_layout)
        glowny_layout.addLayout(przyciski_layout)
        glowny_layout.addWidget(self.tabela)
        glowny_layout.addWidget(self.canvas)

        glowny_widget.setLayout(glowny_layout)
        self.setCentralWidget(glowny_widget)

    def dodaj_wpis_z_formularza(self):
        try:
            id = len(self.manager.wpisy) + 1
            data = datetime.now().strftime("%Y-%m-%d")

            identyfikator = self.input_identyfikator.text()
            licznik = int(self.input_licznik.text())
            ilosc = float(self.input_ilosc.text().replace(",", "."))
            koszt = float(self.input_koszt.text().replace(",", "."))

            wpis = Wpis(
                id,
                identyfikator,
                data,
                licznik,
                ilosc,
                koszt
            )

            self.manager.dodaj_wpis(wpis)

            self.odswiez_tabele()
            self.rysuj_wykres()
            self.wyczysc_formularz()

        except ValueError:
            QMessageBox.warning(
                self,
                "Błąd",
                "Licznik musi być liczbą całkowitą, a ilość i koszt liczbami."
            )

    def odswiez_tabele(self):
        self.tabela.setRowCount(0)

        for wpis in self.manager.wpisy:
            row = self.tabela.rowCount()
            self.tabela.insertRow(row)

            self.tabela.setItem(row, 0, QTableWidgetItem(str(wpis.id)))
            self.tabela.setItem(row, 1, QTableWidgetItem(wpis.identyfikator))
            self.tabela.setItem(row, 2, QTableWidgetItem(wpis.data))
            self.tabela.setItem(row, 3, QTableWidgetItem(str(wpis.licznik)))
            self.tabela.setItem(row, 4, QTableWidgetItem(str(wpis.ilosc)))
            self.tabela.setItem(row, 5, QTableWidgetItem(str(wpis.koszt)))

    def wyczysc_formularz(self):
        self.input_identyfikator.clear()
        self.input_licznik.clear()
        self.input_ilosc.clear()
        self.input_koszt.clear()

    def rysuj_wykres(self):
        dane = self.manager.pobierz_srednie_wszystkich_obiektow()

        self.figure.clear()
        ax = self.figure.add_subplot(111)

        if len(dane) == 0:
            ax.set_title("Brak danych")
            ax.text(
                0.5,
                0.5,
                "Dodaj minimum dwa wpisy dla obiektu",
                ha="center",
                va="center"
            )
        else:
            ax.bar(dane.keys(), dane.values())
            ax.set_title("Średnia wartość według obiektu")
            ax.set_xlabel("Obiekt")
            ax.set_ylabel("Wartość / 100 jednostek")
            ax.tick_params(axis="x", rotation=45)

        self.figure.tight_layout()
        self.canvas.draw()

    def zapisz_json(self):
        sciezka, _ = QFileDialog.getSaveFileName(
            self,
            "Zapisz plik JSON",
            "",
            "Pliki JSON (*.json)"
        )

        if sciezka:
            self.manager.zapisz_baze(sciezka)
            QMessageBox.information(self, "Zapisano", "Dane zapisano do pliku.")

    def wczytaj_json(self):
        sciezka, _ = QFileDialog.getOpenFileName(
            self,
            "Wczytaj plik JSON",
            "",
            "Pliki JSON (*.json)"
        )

        if sciezka:
            self.manager.wczytaj_baze(sciezka)
            self.odswiez_tabele()
            self.rysuj_wykres()
            QMessageBox.information(self, "Wczytano", "Dane wczytano z pliku.")

    def wyczysc_dane(self):
        self.manager.wyczysc_dane()
        self.odswiez_tabele()
        self.rysuj_wykres()


