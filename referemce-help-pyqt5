# Przykład 2 — panel pomiarów

```python
import sys
import json
from datetime import datetime

from PyQt5.QtWidgets import (
    QApplication,
    QMainWindow,
    QWidget,
    QVBoxLayout,
    QHBoxLayout,
    QLabel,
    QLineEdit,
    QPushButton,
    QTableWidget,
    QTableWidgetItem,
    QMessageBox,
    QFileDialog,
    QComboBox
)

from matplotlib.backends.backend_qt5agg import FigureCanvasQTAgg as FigureCanvas
from matplotlib.figure import Figure


class Pomiar:
    def __init__(self, timestamp, miejsce, wartosc, wilgotnosc, pm25):
        self.timestamp = timestamp
        self.miejsce = miejsce
        self.wartosc = wartosc
        self.wilgotnosc = wilgotnosc
        self.pm25 = pm25


class PomiarManager:
    def __init__(self):
        self.pomiary = []

    def dodaj_pomiar(self, pomiar):
        self.pomiary.append(pomiar)

    def wyczysc_dane(self):
        self.pomiary.clear()

    def pobierz_historie_miejsca(self, nazwa_miejsca):
        historia = []

        for pomiar in self.pomiary:
            if pomiar.miejsce == nazwa_miejsca:
                historia.append(pomiar)

        return historia

    def oblicz_srednie(self, nazwa_miejsca):
        historia = self.pobierz_historie_miejsca(nazwa_miejsca)

        if len(historia) == 0:
            return None

        suma_wartosci = 0
        suma_wilgotnosci = 0

        for pomiar in historia:
            suma_wartosci += pomiar.wartosc
            suma_wilgotnosci += pomiar.wilgotnosc

        srednia_wartosc = suma_wartosci / len(historia)
        srednia_wilgotnosc = suma_wilgotnosci / len(historia)

        return srednia_wartosc, srednia_wilgotnosc

    def zapisz_baze(self, sciezka):
        dane = []

        for pomiar in self.pomiary:
            dane.append(pomiar.__dict__)

        with open(sciezka, "w", encoding="utf-8") as plik:
            json.dump(dane, plik, ensure_ascii=False, indent=4)

    def wczytaj_baze(self, sciezka):
        with open(sciezka, "r", encoding="utf-8") as plik:
            dane = json.load(plik)

        self.pomiary = []

        for element in dane:
            pomiar = Pomiar(**element)
            self.pomiary.append(pomiar)


class MainWindow(QMainWindow):
    def __init__(self):
        super().__init__()

        self.manager = PomiarManager()

        self.setWindowTitle("Panel pomiarów")
        self.setGeometry(200, 200, 1100, 750)

        self.utworz_interfejs()

    def utworz_interfejs(self):
        glowny_widget = QWidget()
        glowny_layout = QVBoxLayout()

        formularz_layout = QHBoxLayout()

        self.combo_miejsce = QComboBox()
        self.combo_miejsce.addItems(["Warszawa", "Kraków", "Gdańsk", "Poznań"])

        self.input_wartosc = QLineEdit()
        self.input_wilgotnosc = QLineEdit()
        self.input_pm25 = QLineEdit()

        self.input_wartosc.setPlaceholderText("Wartość")
        self.input_wilgotnosc.setPlaceholderText("Wilgotność")
        self.input_pm25.setPlaceholderText("PM2.5")

        formularz_layout.addWidget(QLabel("Miejsce:"))
        formularz_layout.addWidget(self.combo_miejsce)

        formularz_layout.addWidget(QLabel("Wartość:"))
        formularz_layout.addWidget(self.input_wartosc)

        formularz_layout.addWidget(QLabel("Wilgotność:"))
        formularz_layout.addWidget(self.input_wilgotnosc)

        formularz_layout.addWidget(QLabel("PM2.5:"))
        formularz_layout.addWidget(self.input_pm25)

        przyciski_layout = QHBoxLayout()

        self.przycisk_dodaj = QPushButton("Dodaj pomiar")
        self.przycisk_zapisz = QPushButton("Zapisz")
        self.przycisk_wczytaj = QPushButton("Wczytaj")
        self.przycisk_wyczysc = QPushButton("Wyczyść")
        self.przycisk_wykres = QPushButton("Odśwież wykres")

        self.przycisk_dodaj.clicked.connect(self.dodaj_pomiar_z_formularza)
        self.przycisk_zapisz.clicked.connect(self.zapisz_json)
        self.przycisk_wczytaj.clicked.connect(self.wczytaj_json)
        self.przycisk_wyczysc.clicked.connect(self.wyczysc_dane)
        self.przycisk_wykres.clicked.connect(self.rysuj_wykres)
        self.combo_miejsce.currentTextChanged.connect(lambda: self.rysuj_wykres())

        przyciski_layout.addWidget(self.przycisk_dodaj)
        przyciski_layout.addWidget(self.przycisk_zapisz)
        przyciski_layout.addWidget(self.przycisk_wczytaj)
        przyciski_layout.addWidget(self.przycisk_wyczysc)
        przyciski_layout.addWidget(self.przycisk_wykres)

        self.tabela = QTableWidget()
        self.tabela.setColumnCount(5)
        self.tabela.setHorizontalHeaderLabels([
            "Czas",
            "Miejsce",
            "Wartość",
            "Wilgotność",
            "PM2.5"
        ])

        self.figure = Figure(figsize=(5, 3))
        self.canvas = FigureCanvas(self.figure)

        glowny_layout.addLayout(formularz_layout)
        glowny_layout.addLayout(przyciski_layout)
        glowny_layout.addWidget(self.tabela)
        glowny_layout.addWidget(self.canvas)

        glowny_widget.setLayout(glowny_layout)
        self.setCentralWidget(glowny_widget)

    def dodaj_pomiar_z_formularza(self):
        try:
            timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
            miejsce = self.combo_miejsce.currentText()
            wartosc = float(self.input_wartosc.text().replace(",", "."))
            wilgotnosc = int(self.input_wilgotnosc.text())
            pm25 = int(self.input_pm25.text())

            pomiar = Pomiar(
                timestamp,
                miejsce,
                wartosc,
                wilgotnosc,
                pm25
            )

            self.manager.dodaj_pomiar(pomiar)

            self.odswiez_tabele()
            self.rysuj_wykres()
            self.wyczysc_formularz()

        except ValueError:
            QMessageBox.warning(
                self,
                "Błąd",
                "Wartość musi być liczbą, a wilgotność i PM2.5 liczbami całkowitymi."
            )

    def odswiez_tabele(self):
        self.tabela.setRowCount(0)

        for pomiar in self.manager.pomiary:
            row = self.tabela.rowCount()
            self.tabela.insertRow(row)

            self.tabela.setItem(row, 0, QTableWidgetItem(pomiar.timestamp))
            self.tabela.setItem(row, 1, QTableWidgetItem(pomiar.miejsce))
            self.tabela.setItem(row, 2, QTableWidgetItem(str(pomiar.wartosc)))
            self.tabela.setItem(row, 3, QTableWidgetItem(str(pomiar.wilgotnosc)))
            self.tabela.setItem(row, 4, QTableWidgetItem(str(pomiar.pm25)))

    def wyczysc_formularz(self):
        self.input_wartosc.clear()
        self.input_wilgotnosc.clear()
        self.input_pm25.clear()

    def rysuj_wykres(self):
        miejsce = self.combo_miejsce.currentText()
        historia = self.manager.pobierz_historie_miejsca(miejsce)

        czasy = []
        wartosci = []

        for pomiar in historia:
            czasy.append(pomiar.timestamp[11:19])
            wartosci.append(pomiar.wartosc)

        self.figure.clear()
        ax = self.figure.add_subplot(111)

        if len(historia) == 0:
            ax.set_title("Brak danych")
            ax.text(0.5, 0.5, "Dodaj pomiary", ha="center", va="center")
        else:
            ax.plot(czasy, wartosci, marker="o")
            ax.set_title(f"Trend wartości - {miejsce}")
            ax.set_xlabel("Czas")
            ax.set_ylabel("Wartość")
            ax.tick_params(axis="x", rotation=45)

        self.figure.tight_layout()
        self.canvas.draw()

    def zapisz_json(self):
        sciezka, _ = QFileDialog.getSaveFileName(
            self,
            "Zapisz plik JSON",
            "",
            "Pliki JSON (*.json)"
        )

        if sciezka:
            self.manager.zapisz_baze(sciezka)
            QMessageBox.information(self, "Zapisano", "Dane zapisano do pliku.")

    def wczytaj_json(self):
        sciezka, _ = QFileDialog.getOpenFileName(
            self,
            "Wczytaj plik JSON",
            "",
            "Pliki JSON (*.json)"
        )

        if sciezka:
            self.manager.wczytaj_baze(sciezka)
            self.odswiez_tabele()
            self.rysuj_wykres()
            QMessageBox.information(self, "Wczytano", "Dane wczytano z pliku.")

    def wyczysc_dane(self):
        self.manager.wyczysc_dane()
        self.odswiez_tabele()
        self.rysuj_wykres()


app = QApplication(sys.argv)
window = MainWindow()
window.show()
sys.exit(app.exec_())
