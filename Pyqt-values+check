class Product:
    counter = 1

    def __init__(self, name, category, quantity, price):
        self.product_id = Product.counter
        Product.counter += 1

        self.name = name
        self.category = category
        self.quantity = quantity
        self.price = price

    def total_value(self):
        return self.quantity * self.price


class WarehouseManager:
    def __init__(self):
        self.products = []

    def add_product(self, name, category, quantity, price):
        product = Product(name, category, quantity, price)
        self.products.append(product)

    def remove_product(self, product_id):
        for product in self.products:
            if product.product_id == product_id:
                self.products.remove(product)
                return True
        return False

    def calculate_all_value(self):
        total = 0
        for product in self.products:
            total += product.total_value()
        return total

    def calculate_category_value(self, category):
        total = 0
        for product in self.products:
            if product.category == category:
                total += product.total_value()
        return total
